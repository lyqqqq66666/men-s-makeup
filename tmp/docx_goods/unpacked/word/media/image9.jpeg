  <style>
    @font-face {
      font-family: 'Century Gothic Std';
      src: url('https://www.dior.com/static/fonts/CenturyGothicRegular/CenturyGothicW05-Regular.woff2')
          format('woff2'),
        url('https://www.dior.com/static/fonts/CenturyGothicRegular/CenturyGothicW05-Regular.woff')
          format('woff'),
        url('https://www.dior.com/static/fonts/CenturyGothicRegular/CenturyGothicW05-Regular.ttf')
          format('truetype'),
        url('https://www.dior.com/static/fonts/CenturyGothicRegular/CenturyGothicW05-Regular.eot')
          format('eot');
      font-weight: normal;
      font-style: normal;
      font-display: fallback;
    }
    @font-face {
      font-family: 'Century Gothic Std Bold';
      src: url('https://www.dior.com/static/fonts/CenturyGothicBold/CenturyGothicW05-Bold.woff2')
          format('woff2'),
        url('https://www.dior.com/static/fonts/CenturyGothicBold/CenturyGothicW05-Bold.woff')
          format('woff'),
        url('https://www.dior.com/static/fonts/CenturyGothicBold/CenturyGothicW05-Bold.ttf')
          format('truetype'),
        url('https://www.dior.com/static/fonts/CenturyGothicBold/CenturyGothicW05-Bold.eot')
          format('eot');
      font-weight: bold;
      font-style: normal;
      font-display: fallback;
    }

    .header-light {
      width: 100%;
      display: flex;
      height: 5rem;
      justify-content: center;
      align-items: center;
      border-bottom: .0625rem solid #e5e5e5
    }

    .header-light__logo svg {
      height: 2.5rem;
      width: 7.5rem
    }

    .header-light__logo .icon {
      display: flex
    }

    .error-page {
      padding: 3.75rem 8rem;
      max-width: 50rem
    }

    .error-page-title {
      margin-bottom: 1.125rem!important;
      max-width: 30rem;
    }

    .title-with-level {
      font-family: 'Century Gothic Std',Arial,sans-serif;
      font-weight: 400;
      margin: 0;
      width: 100%;
    }

    .size-l.title-with-level {
      font-size: 2rem;
      line-height: 2.375rem;
    }

    .error-page-description {
      font-family: 'Century Gothic Std',Arial,sans-serif;
      font-size: 15px;
    }
  </style>

